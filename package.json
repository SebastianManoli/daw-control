{
  "name": "daw-control",
  "version": "1.0.0",
  "description": "version control system built for ableton live",
  "main": "src/main/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "electron": "wait-on http://localhost:5173 && electron .",
    "start": "concurrently -k \"npm run dev\" \"npm run electron\"",
    "test": "npm test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SebastianManoli/daw-control.git"
  },
  "author": "Sebastian Manoli",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/SebastianManoli/daw-control/issues"
  },
  "homepage": "https://github.com/SebastianManoli/daw-control#readme",
  "devDependencies": {
    "@vitejs/plugin-react": "^4.7.0",
    "concurrently": "^9.2.1",
    "electron": "^39.2.1",
    "vite": "^5.4.21",
    "wait-on": "^9.0.3"
  },
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  }
}
